{
  "name": "@mohassibe/desktop",
  "version": "1.0.0",
  "description": "Desktop wrapper for Mohassibe Accounting System",
  "author": "Raid",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "31.7.7"
  },
  "build": {
    "appId": "com.mohassibe.desktop",
    "productName": "Mohassibe Desktop",
    "directories": {
      "output": "dist_setup"
    },
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "package.json"
    ]
  }
}
