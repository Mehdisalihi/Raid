generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  passwordHash       String
  phone              String?
  role               String   @default("USER")
  isActive           Boolean  @default(true)
  canAccessSales     Boolean  @default(true)
  canCreateInvoices  Boolean  @default(true)
  canManageInventory Boolean  @default(true)
  canViewReports     Boolean  @default(true)
  canManageCustomers Boolean  @default(true)
  canManageExpenses  Boolean  @default(true)
  canAccessSettings  Boolean  @default(true)
  language           String   @default("ar")
  theme              String   @default("system")
  primaryColor       String   @default("#1E40AF")
  // Store Settings
  storeName          String   @default("My Store")
  storeTaxId         String?
  storeAddress       String?
  storePhone         String?
  storeEmail         String?
  currency           String   @default("MRU")
  isVerified         Boolean  @default(false)
  verificationCode   String?
  createdAt          DateTime @default(now())
}

model Product {
  id                 String               @id @default(uuid())
  name               String
  barcode            String?              @unique
  buyPrice           Float
  sellPrice          Float
  stockQty           Int                  @default(0)
  minStockAlert      Int                  @default(5)
  createdAt          DateTime             @default(now())
  Sales              SaleItem[]
  Movements          StockMovement[]
  WarehouseInventory WarehouseInventory[]
}

model Warehouse {
  id            String               @id @default(uuid())
  name          String
  location      String?
  manager       String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  MovementsTo   StockMovement[]      @relation("destination")
  MovementsFrom StockMovement[]      @relation("source")
  Inventory     WarehouseInventory[]
}

model WarehouseInventory {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  qty         Int       @default(0)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

model StockMovement {
  id            String     @id @default(uuid())
  productId     String
  sourceId      String?
  destinationId String?
  qty           Int
  type          String
  userId        String?
  notes         String?
  createdAt     DateTime   @default(now())
  destination   Warehouse? @relation("destination", fields: [destinationId], references: [id])
  source        Warehouse? @relation("source", fields: [sourceId], references: [id])
  product       Product    @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([sourceId])
  @@index([destinationId])
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  email     String?
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  Invoices  Invoice[]
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  email     String?
  company   String?
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  Invoices  Invoice[]
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  category    String
  date        DateTime @default(now())
  description String?
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Invoice {
  id            String     @id @default(uuid())
  invoiceNo     String     @unique
  customerId    String?
  supplierId    String?
  totalAmount   Float
  discount      Float      @default(0)
  taxRate       Float      @default(0)
  taxAmount     Float      @default(0)
  finalAmount   Float
  type          String     @default("SALE")
  isDebt        Boolean    @default(false)
  paymentMethod String     @default("cash")
  createdAt     DateTime   @default(now())
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])
  customer      Customer?  @relation(fields: [customerId], references: [id])
  items         SaleItem[]

  @@index([customerId])
  @@index([supplierId])
  @@index([createdAt])
  @@index([type])
}

model SaleItem {
  id        String  @id @default(uuid())
  invoiceId String
  productId String
  qty       Int
  price     Float
  total     Float
  product   Product @relation(fields: [productId], references: [id])
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model Staff {
  id           String              @id @default(uuid())
  name         String
  phone        String?
  role         String?
  baseSalary   Float               @default(0)
  balance      Float               @default(0) // Total Salary Earned - Total Paid/Advances
  isActive     Boolean             @default(true)
  joinedAt     DateTime            @default(now()) // New field: Start date
  createdAt    DateTime            @default(now())
  Transactions SalaryTransaction[]
}

model SalaryTransaction {
  id           String   @id @default(uuid())
  staffId      String
  type         String // "SALARY" (Credit), "PAYMENT" (Debit), "ADVANCE" (Debit)
  amount       Float
  balanceAfter Float    @default(0) // The staff's balance after this specific transaction
  date         DateTime @default(now())
  description  String?
  staff        Staff    @relation(fields: [staffId], references: [id])

  @@index([staffId])
}
